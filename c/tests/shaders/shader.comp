#version 450

layout(local_size_x = 16, local_size_y = 16) in;

layout(binding = 0) buffer MatrixA {
    float a[];
};

layout(binding = 1) buffer MatrixB {
    float b[];
};

layout(binding = 2) buffer MatrixC {
    float c[];
};

layout(push_constant) uniform PushConstants {
    int rows;
    int cols;
    int inner;
} constants;

void main() {
    uint row = gl_GlobalInvocationID.y;
    uint col = gl_GlobalInvocationID.x;
    if (row >= uint(constants.rows) || col >= uint(constants.cols)) {
        return;
    }

    float result = 0.0;
    for (int k = 0; k < constants.inner; ++k) {
        result += a[row * constants.inner + k] * b[k * constants.cols + col];
    }
    c[row * constants.cols + col] = result;
}
