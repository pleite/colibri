# syntax=docker/dockerfile:1.7
# Colibri backend container image for Vulkan, ROCm, or NPU-enabled builds.
FROM fedora:43 AS build

ARG BACKEND=vulkan

ENV ROCM_PATH=/opt/rocm \
    HIP_PATH=/opt/rocm \
    HIP_CLANG_PATH=/opt/rocm/llvm/bin \
    HIP_DEVICE_LIB_PATH=/opt/rocm/amdgcn/bitcode \
    PATH=/opt/rocm/bin:/opt/rocm/llvm/bin:$PATH

RUN set -e && \
    dnf install -y --setopt=install_weak_deps=False \
        gcc gcc-c++ make git python3 python3-pip \
        ca-certificates curl gnupg dnf-plugins-core \
    && case "$BACKEND" in \
        rocm|all) \
           # Enable the community ROCm COPR repo for Fedora since the stock Fedora repos do not provide the ROCm toolchain packages. \
           dnf copr enable -y tpitera/rocm && \
           dnf install -y --setopt=install_weak_deps=False \
               rocm-hip-sdk rocm-hip-devel hipcc rocm-smi ;; \
    esac \
    && case "$BACKEND" in \
        vulkan|all) \
           dnf install -y --setopt=install_weak_deps=False \
               vulkan-devel vulkan-tools glslc spirv-tools mesa-vulkan-drivers vulkan-loader ;; \
    esac \
    && case "$BACKEND" in \
        npu|all) \
           # Enable the community AMD/XRT COPR repo because XRT is not shipped in the stock Fedora repositories. \
           dnf copr enable -y xanderlent/amd-npu-driver && \
           dnf install -y --setopt=install_weak_deps=False xrt ;; \
    esac \
    && dnf clean all

WORKDIR /opt/colibri/c
COPY c /opt/colibri/c

RUN make clean && case "$BACKEND" in \
        vulkan) make VULKAN=1 glm qwen35_moe ;; \
        rocm) make ROCM=1 glm qwen35_moe ;; \
        npu) make NPU=1 glm qwen35_moe ;; \
        all) make VULKAN=1 ROCM=1 NPU=1 glm qwen35_moe ;; \
    esac

EXPOSE 8000
CMD ["python3", "/opt/colibri/c/openai_server.py", "--host", "0.0.0.0", "--port", "8000"]
