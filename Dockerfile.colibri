# syntax=docker/dockerfile:1.7
# Colibri backend container image for Vulkan, ROCm, or NPU-enabled builds.
FROM ubuntu:24.04 AS build

ARG BACKEND=vulkan
ARG XRT_DEB_URL=

ENV DEBIAN_FRONTEND=noninteractive \
    ROCM_PATH=/opt/rocm \
    HIP_PATH=/opt/rocm \
    HIP_CLANG_PATH=/opt/rocm/llvm/bin \
    HIP_DEVICE_LIB_PATH=/opt/rocm/amdgcn/bitcode \
    PATH=/opt/rocm/bin:/opt/rocm/llvm/bin:$PATH

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential gcc g++ make git python3 python3-pip \
        ca-certificates curl gnupg \
    && rm -rf /var/lib/apt/lists/*

RUN case "$BACKEND" in \
        rocm|all) \
            curl -fsSL https://repo.radeon.com/rocm/rocm.gpg.key | gpg --dearmor -o /usr/share/keyrings/rocm.gpg && \
            echo "deb [arch=amd64 signed-by=/usr/share/keyrings/rocm.gpg] https://repo.radeon.com/rocm/apt/7.2.4/ ubuntu main" \
                > /etc/apt/sources.list.d/rocm.list ;; \
    esac

RUN install_xrt_deps() { \
        if apt-cache show xrt >/dev/null 2>&1 && apt-cache show libxrt-dev >/dev/null 2>&1; then \
            apt-get update && apt-get install -y --no-install-recommends \
                xrt libxrt-dev \
            && rm -rf /var/lib/apt/lists/*; \
        elif [ -n "$XRT_DEB_URL" ]; then \
            curl -fsSL "$XRT_DEB_URL" -o /tmp/xrt.deb && \
            apt-get update && apt-get install -y --no-install-recommends /tmp/xrt.deb \
            && rm -f /tmp/xrt.deb \
            && rm -rf /var/lib/apt/lists/*; \
        else \
            echo "xrt/libxrt-dev is not available in the configured Apt sources; provide XRT_DEB_URL to a compatible .deb or add the appropriate repository (for example from https://github.com/Xilinx/XRT)." >&2; \
            exit 1; \
        fi; \
    }; \
    case "$BACKEND" in \
        vulkan) \
            apt-get update && apt-get install -y --no-install-recommends \
                libvulkan-dev vulkan-tools glslang-tools spirv-tools \
                mesa-vulkan-drivers libvulkan1 \
            && rm -rf /var/lib/apt/lists/* ;; \
        rocm) \
            apt-get update && apt-get install -y --no-install-recommends \
                rocm-llvm rocm-device-libs hip-runtime-amd hip-devel rocblas rocblas-dev \
                hipblas hipblas-dev rocm-cmake libomp-dev \
            && rm -rf /var/lib/apt/lists/* ;; \
        npu) \
            install_xrt_deps ;; \
        all) \
            apt-get update && apt-get install -y --no-install-recommends \
                libvulkan-dev vulkan-tools glslang-tools spirv-tools \
                mesa-vulkan-drivers libvulkan1 \
                rocm-llvm rocm-device-libs hip-runtime-amd hip-devel rocblas rocblas-dev \
                hipblas hipblas-dev rocm-cmake libomp-dev \
            && rm -rf /var/lib/apt/lists/* \
            && install_xrt_deps ;; \
        *) echo "unsupported backend: $BACKEND" >&2; exit 1 ;; \
    esac

WORKDIR /opt/colibri/c
COPY c /opt/colibri/c

RUN make clean && case "$BACKEND" in \
        vulkan) make VULKAN=1 glm qwen35_moe ;; \
        rocm) make ROCM=1 glm qwen35_moe ;; \
        npu) make NPU=1 glm qwen35_moe ;; \
        all) make VULKAN=1 ROCM=1 NPU=1 glm qwen35_moe ;; \
    esac

EXPOSE 8000
CMD ["python3", "/opt/colibri/c/openai_server.py", "--host", "0.0.0.0", "--port", "8000"]
