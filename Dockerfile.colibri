FROM registry.fedoraproject.org/fedora:42

# Build deps + runtime deps (python3 for openai_server.py)
# ROCm/Vulkan support: rocm-dev, vulkan-headers, rocm-opencl-runtime
RUN dnf install -y gcc gcc-c++ make git python3 python3-pip \
    rocm-dev vulkan-headers rocm-opencl-runtime \
    && dnf clean all

WORKDIR /opt/colibri

# Clone from pleite mirror
RUN git clone https://github.com/pleite/colibri.git .

# Build the C engine with ROCm/Vulkan support
WORKDIR /opt/colibri/c
RUN ./setup.sh 2>&1

# Expose OpenAI-compatible API port
EXPOSE 8000

# Default: run the OpenAI server
CMD ["python3", "openai_server.py", "--host", "0.0.0.0", "--port", "8000"]
