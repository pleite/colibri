# syntax=docker/dockerfile:1.7
# Colibri backend container image for Vulkan, ROCm, or NPU-enabled builds.
FROM registry.fedoraproject.org/fedora:43 AS build

ARG BACKEND=vulkan

ENV ROCM_PATH=/opt/rocm \
    HIP_PATH=/opt/rocm \
    HIP_CLANG_PATH=/opt/rocm/llvm/bin \
    HIP_DEVICE_LIB_PATH=/opt/rocm/amdgcn/bitcode \
    PATH=/opt/rocm/bin:/opt/rocm/llvm/bin:$PATH \
    COLI_ACCEL=cpu

RUN set -e && dnf install -y --setopt=install_weak_deps=False \
        gcc gcc-c++ make git python3 python3-pip \
        ca-certificates curl gnupg \
    && dnf clean all

RUN set -e && \
    case "$BACKEND" in cpu|vulkan|rocm|npu|all) ;; \
        *) echo "unsupported backend: $BACKEND (valid values: cpu, vulkan, rocm, npu, all [installs every backend])" >&2; exit 1 ;; \
    esac && \
    if [ "$BACKEND" = vulkan ] || [ "$BACKEND" = all ]; then \
        dnf install -y --setopt=install_weak_deps=False \
            vulkan-devel vulkan-tools spirv-tools glslc libshaderc-devel \
            mesa-vulkan-drivers vulkan-loader \
        && dnf clean all; \
    fi && \
    if [ "$BACKEND" = rocm ] || [ "$BACKEND" = all ]; then \
        printf '%s\n' \
            '[ROCm-7.2.4]' \
            'name=ROCm7.2.4' \
            'baseurl=https://repo.radeon.com/rocm/rhel10/7.2.4/main' \
            'enabled=1' \
            'priority=50' \
            'gpgcheck=1' \
            'gpgkey=https://repo.radeon.com/rocm/rocm.gpg.key' \
            > /etc/yum.repos.d/rocm.repo && \
        dnf install -y --setopt=install_weak_deps=False \
            --exclude='*sdk*' --exclude='*samples*' --exclude='*-doc*' --exclude='*-docs*' \
            cmake lld clang clang-devel compiler-rt libcurl-devel ninja-build \
            rocm-llvm rocm-device-libs hip-runtime-amd hip-devel \
            rocblas rocblas-devel hipblas hipblas-devel rocm-cmake libomp-devel libomp \
            rocminfo radeontop \
        && dnf clean all; \
    fi && \
    if [ "$BACKEND" = npu ] || [ "$BACKEND" = all ]; then \
        dnf install -y --setopt=install_weak_deps=False dnf-plugins-core && \
        dnf copr enable -y xanderlent/amd-npu-driver && \
        dnf install -y --setopt=install_weak_deps=False xrt && \
        dnf clean all; \
    fi

WORKDIR /opt/colibri/c
COPY c /opt/colibri/c

RUN make clean && case "$BACKEND" in \
        cpu) make glm qwen35_moe ;; \
        vulkan) make VULKAN=1 glm qwen35_moe ;; \
        rocm) make ROCM=1 glm qwen35_moe ;; \
        npu) make NPU=1 glm qwen35_moe ;; \
        all) make VULKAN=1 ROCM=1 NPU=1 glm qwen35_moe ;; \
    esac

EXPOSE 8000
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD python3 - <<'PY'
import sys
import urllib.request

try:
    with urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=2) as response:
        response.read()
except Exception:
    sys.exit(1)
PY
CMD ["python3", "/opt/colibri/c/openai_server.py", "--host", "0.0.0.0", "--port", "8000"]
